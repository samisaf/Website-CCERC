---
import PageLayout from "../layouts/PageLayout.astro";
import PageMeta from "../components/PageMeta.astro";
import { SITE_TITLE } from "../config";
import * as markdown from "../../content/publications.md"
import { main as fetchPubmed } from "../../scripts/fetch-pubmed.mjs";
import { updatePublications } from "../../scripts/update-publications.mjs";

const { fetchPubmed: shouldFetch, updatePublications: shouldUpdate } = markdown.frontmatter;

if (shouldFetch) {
  await fetchPubmed();
}

if (shouldUpdate) {
  await updatePublications();
}

const title = "Notable Publications";
---

<PageLayout>
  <PageMeta title={`Publications | ${SITE_TITLE}`} slot="meta" />
  <section>
    <h2 >{title}</h2>
    <Fragment set:html={markdown.compiledContent()} />
  </section>
</PageLayout>